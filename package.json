{
  "name": "voice-emotion-detection",
  "version": "1.0.0",
  "description": "Voice emotion detection — Next.js frontend + Express backend",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:backend": "node --dns-result-order=ipv4first backend/server.js",
    "dev:frontend": "next dev -p 3001",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "build": "next build",
    "start": "node --dns-result-order=ipv4first backend/server.js",
    "lint": "eslint"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@huggingface/inference": "^4.13.15",
    "@supabase/supabase-js": "^2.50.2",
    "@types/three": "^0.183.1",
    "axios": "^1.15.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "fluent-ffmpeg": "^2.1.3",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.8.0",
    "mime-types": "^3.0.2",
    "multer": "^1.4.5-lts.1",
    "next": "16.2.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.2.0",
    "tailwind-merge": "^3.5.0",
    "three": "^0.183.2",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
