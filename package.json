{
  "name": "voice-emotion-detection-backend",
  "version": "1.0.0",
  "description": "NPM backend for voice emotion detection",
  "main": "backend/server.js",
  "type": "commonjs",
  "scripts": {
    "dev:backend": "node --dns-result-order=ipv4first backend/server.js",
    "dev:frontend": "cd frontend && npm run dev -- -p 3001",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "start": "node --dns-result-order=ipv4first backend/server.js",
    "check": "node --check backend/server.js"
  },
  "keywords": [
    "voice",
    "emotion",
    "speech",
    "ser",
    "express"
  ],
  "license": "MIT",
  "dependencies": {
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@huggingface/inference": "^4.13.15",
    "@supabase/supabase-js": "^2.50.2",
    "axios": "^1.15.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "fluent-ffmpeg": "^2.1.3",
    "mime-types": "^3.0.2",
    "multer": "^1.4.5-lts.1"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
